# LLM Configuration (Cloudflare AI Gateway)
CF_AIG_TOKEN=your_token_here
CF_AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/xxx/default/compat
GEMMA_MODEL=google-ai-studio/gemma-4-31b-it

# McDonald's MCP (optional - falls back to mock if not set)
MCD_MCP_TOKEN=your_mcdonalds_mcp_token_here
MCD_MCP_URL=https://mcp.mcd.cn
USE_MOCK_MCP=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./eatornot.db

# App
APP_NAME=EatOrNot
DEBUG=true
