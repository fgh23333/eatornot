# ==================================
# EatOrNot 环境变量配置
# 复制为 .env 后填入你的值
# ==================================

# ---- LLM (Cloudflare AI Gateway) ----
# 从 Cloudflare dashboard 获取:
#   AI Gateway → 创建 gateway → 获取 API token
CF_AIG_TOKEN=your_cloudflare_aig_token_here
CF_AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY/compat
GEMMA_MODEL=google-ai-studio/gemma-4-31b-it

# ---- McDonald's MCP (可选) ----
# 不配置时自动使用 Mock 数据
MCD_MCP_TOKEN=
MCD_MCP_URL=https://mcp.mcd.cn
USE_MOCK_MCP=true

# ---- Database ----
# Docker 环境下会自动覆盖为 SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/eatornot.db

# ---- App ----
APP_NAME=EatOrNot
DEBUG=true

# ---- Web Push (可选) ----
# 生成 VAPID 密钥对: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
